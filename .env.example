# --- AI providers (set at least one) ---
# Anthropic — preferred for /api/plan (reliable JSON + vision).
ANTHROPIC_API_KEY=sk-ant-...
# Optional: fallback secondary Anthropic key. Used only if ANTHROPIC_API_KEY is empty.
ANTHROPIC_API_KEY_V2=
# Blackbox — OpenAI-compatible proxy. Cheap default for /api/chat (DeepSeek).
# Note: prompts/completions flow through Blackbox's servers.
BLACKBOX_API_KEY=
# Optional Blackbox model overrides. Defaults: deepseek-chat / anthropic/claude-3.5-sonnet
BLACKBOX_CHAT_MODEL=
BLACKBOX_PLAN_MODEL=
# OpenAI direct (optional fallback).
OPENAI_API_KEY=
# Hugging Face Inference Providers (optional, experimental lane).
# Canonical token var: HF_TOKEN
# Fallback alias (accepted by router): HUGGINGFACE_API_KEY
HF_TOKEN=
HUGGINGFACE_API_KEY=
# Optional model overrides for Hugging Face lane.
HUGGINGFACE_CHAT_MODEL=
HUGGINGFACE_PLAN_MODEL=

# Routing:
#   PLANIFIER_MODEL=auto         -> use lib/ai/router.ts rules (recommended)
#   PLANIFIER_MODEL=gpt-4o       -> force literal OpenAI model id
#   PLANIFIER_MODEL=claude-...   -> force literal Anthropic model id
#   PLANIFIER_MODEL=huggingface  -> force Hugging Face lane using HUGGINGFACE_*_MODEL
#   PLANIFIER_MODEL=huggingface:<model-id> -> force a specific Hugging Face model
PLANIFIER_MODEL=auto
# Optional: override the fallback chain for the "plan" / quality task.
# Comma-separated, first match wins. Default: anthropic,blackbox,openai
PROVIDERS_PREFERRED=anthropic,blackbox,openai

# --- Public app URL ---
# Used for canonical metadata, robots.txt, sitemap.xml, and production smoke docs.
NEXT_PUBLIC_APP_URL=https://planifier.cloud

# --- Database (Neon Postgres via Vercel Marketplace recommended) ---
# Standard pooled connection string. The @neondatabase/serverless driver
# works over HTTP, so any Neon connection string works in dev and on Vercel.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/planifier?sslmode=require

# --- Clerk auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
