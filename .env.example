# --- OpenAI ---
OPENAI_API_KEY=sk-...
# Optional: pick the model (default: gpt-4o)
PLANIFIER_MODEL=gpt-4o

# --- Database (Neon Postgres via Vercel Marketplace recommended) ---
# Standard pooled connection string. The @neondatabase/serverless driver
# works over HTTP, so any Neon connection string works in dev and on Vercel.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/planifier?sslmode=require

# --- Clerk auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
